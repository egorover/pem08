# ========================================
# AI-Анализатор рынка онлайн-кинотеатров
# ========================================

# ProxyAPI Configuration (OpenAI-совместимый API для России)
# Получить ключ: https://proxyapi.ru/
# Документация: https://proxyapi.ru/docs/openai-text-generation

PROXY_API_KEY=your-PROXY_API_KEY

# Модели (опционально, по умолчанию gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Доступные модели ProxyAPI:
# - gpt-4o (лучшее качество)
# - gpt-4o-mini (баланс цена/качество)
# - gpt-4-turbo
# - gpt-3.5-turbo

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Парсер Configuration
PARSER_TIMEOUT=10
PARSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Конкуренты для массового парсинга (через запятую)
COMPETITORS_URLS=https://kinopoisk.ru,https://ivi.ru,https://wink.ru